// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: /users/{userId}
// Document ID: userId
// Fields:
//   - uid: string (required) - User's unique ID
//   - email: string (required) - User's email
//   - displayName: string (optional) - User's display name
//   - photoURL: string (optional) - User's profile picture URL
//   - createdAt: timestamp (required) - Account creation time
//
// Collection: /users/{userId}/collection/{itemId}
// Document ID: itemId (auto-generated)
// Fields:
//   - userId: string (required) - Owner's UID
//   - fruitName: string (required) - Name of the fruit
//   - scientificName: string (optional) - Latin name
//   - family: string (optional) - Botanical family
//   - origin: string (optional) - Geographical origin
//   - nutrition: map (optional) - Nutritional data
//   - funFact: string (optional) - Trivia
//   - season: string (optional) - Harvest season
//   - imageUrl: string (required) - URL of the uploaded image
//   - timestamp: timestamp (required) - Identification time
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "zechengxu10@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             data.email.size() < 255;
    }

    function isValidFruitEntry(data) {
      return data.keys().hasAll(['userId', 'fruitName', 'imageUrl', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.fruitName is string && data.fruitName.size() < 100 &&
             data.imageUrl is string && data.imageUrl.size() < 2000 &&
             data.timestamp is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                    request.resource.data.uid == resource.data.uid;

      match /collection/{itemId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidFruitEntry(request.resource.data);
        allow update: if isOwner(userId) && isValidFruitEntry(request.resource.data) &&
                      request.resource.data.userId == resource.data.userId;
        allow delete: if isOwner(userId);
      }
    }
  }
}
